% refs.bib — ECE 50874 Failure Analysis Template
%
% Add one BibTeX entry per source you cite, then cite it in the .tex with:
%   \cite{key}
%
% IMPORTANT: The entry type depends on what the source is:
%   - Web page / blog / online report
%   - Conference paper
%   - Journal article
%   - Book
%   - Technical report / whitepaper
%   - Manual / documentation
%
% Reference guide: https://www.overleaf.com/learn/latex/Bibliography_management_with_bibtex

@misc{source_example,
  author = {LASTNAME, Firstname and LASTNAME, Firstname},
  title  = {TITLE OF SOURCE},
  year   = {YYYY},
  url    = {https://example.com/},
  note   = {Accessed: YYYY-MM-DD}
}


